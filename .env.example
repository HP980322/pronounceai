# -- Required ----------------------------------
# Get a FREE key at: https://aistudio.google.com/apikey
# No credit card required!
GEMINI_API_KEY=AIza...

# -- Optional ----------------------------------
PORT=3000

# Gemini model (default is free-tier Flash-Lite, 1000 req/day)
# Other free options: gemini-2.5-flash (250/day), gemini-2.5-pro (100/day)
GEMINI_MODEL=gemini-2.5-flash-lite

# Rate limiting per IP
RATE_LIMIT=5
RATE_WINDOW_MS=600000

# Max transcript characters
MAX_CHARS=2000

# Lock to your domain in production
# ALLOWED_ORIGIN=https://yourdomain.com
